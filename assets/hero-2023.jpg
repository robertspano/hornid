<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: Georgia, 'Times New Roman', serif;
    background: #1a1008;
    color: #e8d5b0;
    min-height: 100vh;
  }

  .page {
    min-height: 100vh;
    background: linear-gradient(rgba(16,8,2,0.65), rgba(16,8,2,0.80)),
                url('https://hornid.is/wp-content/uploads/2023/01/hero.jpg') center/cover no-repeat;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px 24px;
    gap: 0;
  }

  .hero-img {
    width: 100%;
    max-width: 240px;
    max-height: 150px;
    object-fit: cover;
    margin-bottom: 36px;
  }

  .logo {
    width: 220px;
    max-width: 70vw;
    margin-bottom: 36px;
  }

  .eyebrow {
    font-size: 18px;
    letter-spacing: 5px;
    color: #c67b5c;
    text-transform: uppercase;
    margin-bottom: 40px;
  }

  .divider {
    width: 44px;
    height: 1px;
    background: #c67b5c;
    margin: 0 auto 40px;
  }

  .ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-outline {
    border: 1px solid #c67b5c;
    color: #c67b5c;
    padding: 18px 36px;
    font-size: 14px;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-decoration: none;
    font-family: Georgia, serif;
    line-height: 1.8;
    transition: background 0.2s, color 0.2s;
  }
  .btn-outline:hover { background: #c67b5c; color: #1a1008; }

  .btn-fill {
    background: #c67b5c;
    color: #1a1008;
    padding: 18px 36px;
    font-size: 14px;
    letter-spacing: 3px;
    text-transform: uppercase;
    text-decoration: none;
    font-family: Georgia, serif;
    font-weight: bold;
    line-height: 1.8;
    transition: background 0.2s;
  }
  .btn-fill:hover { background: #d98c6d; }

  .btn-sub {
    display: block;
    font-size: 9px;
    opacity: 0.7;
    letter-spacing: 2px;
  }

  .note {
    margin-top: 40px;
    font-size: 16px;
    letter-spacing: 2px;
    color: rgba(232,213,176,0.85);
    text-transform: uppercase;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    justify-content: center;
  }

  .note a {
    color: rgba(232,213,176,0.85);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .note a:hover { color: #c67b5c; }

  .social {
    margin-top: 24px;
    display: flex;
    gap: 20px;
    justify-content: center;
    align-items: center;
  }
  .social a {
    color: rgba(232,213,176,0.7);
    text-decoration: none;
    transition: color 0.2s;
  }
  .social a:hover { color: #c67b5c; }

  @media (max-width: 480px) {
    .logo { width: 180px; }
    .eyebrow { font-size: 15px; letter-spacing: 3px; }
    .ctas { flex-direction: column; align-items: center; }
    .btn-outline, .btn-fill { width: 260px; text-align: center; font-size: 13px; }
    .note { font-size: 14px; }
  }
</style>
</head>
<body>
  <div class="page">
    <img class="hero-img" src="https://hornid.is/wp-content/uploads/2026/05/hero.jpg" alt="Hornið">
    <img class="logo" src="https://hornid.is/wp-content/uploads/2023/01/cropped-Hornid-Logo-stort.png" alt="Hornið">
    <div class="eyebrow">Est. 1979 · Reykjavík</div>
    <div class="divider"></div>
    <div class="ctas">
